# ────────────────────────────────────────────────────────────────────────────
# Microsoft Entra Configuration
# ────────────────────────────────────────────────────────────────────────────

# Your Azure AD / Entra tenant ID
TENANT_ID=your-tenant-id-here

# The Application (client) ID of the Agent Identity Blueprint app registration.
# The Blueprint is the "factory" that issues Agent Identity tokens via FIC/WIF.
BLUEPRINT_APP_ID=your-blueprint-app-id-here

# Client secret for the Blueprint app (local dev only).
# For Azure / WIF production deployments, replace the sidecar credential source
# in docker-compose.yml with SignedAssertionFromManagedIdentity — no secret needed.
BLUEPRINT_CLIENT_SECRET=your-blueprint-client-secret-here

# The Application (client) ID of the individual Agent Identity (service principal).
# The sidecar will request a token *for* this identity when asked for an auth header.
AGENT_CLIENT_ID=your-agent-identity-client-id-here

# The OAuth 2.0 scope the sidecar requests when minting the Entra Agent Identity JWT.
# This produces an Entra token whose `aud` claim equals your registered API app's URI.
# The value here must match the audience configured in your Anthropic Console
# federation issuer so that Anthropic can validate the token.
# Typical format: api://<blueprint-app-id>/.default  — or a dedicated WIF app's scope.
# See README for full setup instructions.
ENTRA_WIF_SCOPE=api://your-blueprint-app-id-here/.default

# ────────────────────────────────────────────────────────────────────────────
# Anthropic Workload Identity Federation Configuration
# ────────────────────────────────────────────────────────────────────────────

# The Anthropic service account ID (starts with "svac_").
# Create this in the Anthropic Console under Settings → Service Accounts.
ANTHROPIC_SERVICE_ACCOUNT_ID=svac_your-service-account-id-here

# Your Anthropic organization UUID.
# Find it in the Anthropic Console under Settings → Organization.
ANTHROPIC_ORGANIZATION_ID=00000000-0000-0000-0000-000000000000

# The federation rule ID (starts with "fdrl_") that links your Entra issuer
# to the service account above.
# Create it in the Anthropic Console under Settings → Workload Identity Federation.
ANTHROPIC_FEDERATION_RULE_ID=fdrl_your-federation-rule-id-here

# Claude model to use.
# Example values: claude-3-5-sonnet-20241022, claude-3-haiku-20240307
CLAUDE_MODEL=claude-3-5-sonnet-20241022
